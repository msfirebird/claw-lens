{
  "name": "claw-lens-cli",
  "version": "0.1.0",
  "description": "Observability devtool for OpenClaw. See what your AI agent is doing — cost monitoring, behavior tracing, and security audit.",
  "bin": {
    "claw-lens": "dist/bin/claw-lens.js"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:ui\"",
    "dev:server": "ts-node-dev --respawn --transpile-only src/server/index.ts",
    "dev:ui": "cd src/ui && npm run dev",
    "build": "npm run build:server && npm run build:ui",
    "build:server": "tsc",
    "build:ui": "cd src/ui && npm run build",
    "parse": "ts-node src/server/parser.ts",
    "ingest": "ts-node src/server/db.ts",
    "start": "node dist/bin/claw-lens.js",
    "prepare": "npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "glob": "^10.3.10",
    "minimatch": "^10.2.4",
    "simple-statistics": "^7.8.9",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/src/server/index.js",
  "repository": { "type": "git", "url": "https://github.com/msfirebird/claw-lens" },
  "homepage": "https://claw-lens.com",
  "bugs": { "url": "https://github.com/msfirebird/claw-lens/issues" },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "keywords": [
    "openclaw",
    "observability",
    "ai-agents",
    "dashboard",
    "llm",
    "security-audit",
    "typescript",
    "devtools",
    "tracing",
    "openai",
    "claude",
    "cost-monitoring"
  ]
}
